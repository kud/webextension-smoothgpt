{
  "manifest_version": 2,
  "name": "SmoothGPT",
  "description": "Makes long ChatGPT conversations fast by virtualising off-screen message turns with CSS containment.",
  "version": "1.0.6",
  "browser_specific_settings": {
    "gecko": {
      "id": "smoothgpt@kud.io",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["activeTab", "storage"],
  "browser_action": {
    "default_title": "SmoothGPT",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/icons/icon.svg",
      "32": "src/icons/icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "src/icons/icon.svg",
    "96": "src/icons/icon.svg",
    "128": "src/icons/icon.svg"
  }
}
